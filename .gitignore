/horde

# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# SQLite
*.db
*.db-journal
*.db-wal
*.db-shm

# horde local data (except project config)
.horde/*
!.horde/config.yaml
.env

# beads (local state — mounted into containers, not tracked in git)
.beads/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Claude Code per-session runtime state (lockfiles, local settings,
# scheduled-task working dirs). Intentionally NOT ignoring the whole
# .claude/ dir — hooks or project-scoped agent prompts would live there.
.claude/*.lock
.claude/settings.local.json
.claude/scheduled_tasks/

# OS
.DS_Store
Thumbs.db

# CDK
cdk/node_modules/
cdk/lib/**/*.js
cdk/lib/**/*.d.ts
cdk/test/**/*.js
cdk/test/**/*.d.ts
cdk/cdk.out/
# CDK writes cached context (AZs, AMIs, etc.) here on synth. Checking it in
# is the upstream recommendation for apps, but we treat cdk/ as a library
# and cdk/e2e/ as a throwaway test app, so regenerating is fine.
cdk/cdk.context.json
