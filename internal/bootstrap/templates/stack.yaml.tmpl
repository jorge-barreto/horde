AWSTemplateFormatVersion: "2010-09-09"
Description: "horde stack for project {{.Slug}}"

Parameters:
  ClaudeCodeOauthToken:
    Type: String
    NoEcho: true
    Description: "Claude CLI OAuth token used by the worker container (from 'claude setup-token')"
    MinLength: 1
  GitToken:
    Type: String
    NoEcho: true
    Description: "Git provider token used by the worker container for clone/push"
    MinLength: 1

Resources:
  VPC:
    Type: AWS::EC2::VPC
    Properties:
      CidrBlock: "10.0.0.0/16"
      EnableDnsHostnames: true
      EnableDnsSupport: true
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-vpc"

  InternetGateway:
    Type: AWS::EC2::InternetGateway
    Properties:
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-igw"

  InternetGatewayAttachment:
    Type: AWS::EC2::VPCGatewayAttachment
    Properties:
      VpcId:
        Ref: VPC
      InternetGatewayId:
        Ref: InternetGateway

  PublicSubnet1:
    Type: AWS::EC2::Subnet
    Properties:
      VpcId:
        Ref: VPC
      CidrBlock: "10.0.1.0/24"
      AvailabilityZone:
        Fn::Select:
          - 0
          - Fn::GetAZs: ""
      MapPublicIpOnLaunch: true
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-public-1"

  PublicSubnet2:
    Type: AWS::EC2::Subnet
    Properties:
      VpcId:
        Ref: VPC
      CidrBlock: "10.0.2.0/24"
      AvailabilityZone:
        Fn::Select:
          - 1
          - Fn::GetAZs: ""
      MapPublicIpOnLaunch: true
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-public-2"

  PrivateSubnet1:
    Type: AWS::EC2::Subnet
    Properties:
      VpcId:
        Ref: VPC
      CidrBlock: "10.0.11.0/24"
      AvailabilityZone:
        Fn::Select:
          - 0
          - Fn::GetAZs: ""
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-private-1"

  PrivateSubnet2:
    Type: AWS::EC2::Subnet
    Properties:
      VpcId:
        Ref: VPC
      CidrBlock: "10.0.12.0/24"
      AvailabilityZone:
        Fn::Select:
          - 1
          - Fn::GetAZs: ""
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-private-2"

  NatGatewayEIP:
    Type: AWS::EC2::EIP
    DependsOn: InternetGatewayAttachment
    Properties:
      Domain: vpc

  NatGateway:
    Type: AWS::EC2::NatGateway
    Properties:
      AllocationId:
        Fn::GetAtt:
          - NatGatewayEIP
          - AllocationId
      SubnetId:
        Ref: PublicSubnet1
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-nat"

  PublicRouteTable:
    Type: AWS::EC2::RouteTable
    Properties:
      VpcId:
        Ref: VPC
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-public-rt"

  PublicDefaultRoute:
    Type: AWS::EC2::Route
    DependsOn: InternetGatewayAttachment
    Properties:
      RouteTableId:
        Ref: PublicRouteTable
      DestinationCidrBlock: "0.0.0.0/0"
      GatewayId:
        Ref: InternetGateway

  PublicSubnet1RouteAssoc:
    Type: AWS::EC2::SubnetRouteTableAssociation
    Properties:
      RouteTableId:
        Ref: PublicRouteTable
      SubnetId:
        Ref: PublicSubnet1

  PublicSubnet2RouteAssoc:
    Type: AWS::EC2::SubnetRouteTableAssociation
    Properties:
      RouteTableId:
        Ref: PublicRouteTable
      SubnetId:
        Ref: PublicSubnet2

  PrivateRouteTable:
    Type: AWS::EC2::RouteTable
    Properties:
      VpcId:
        Ref: VPC
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-private-rt"

  PrivateDefaultRoute:
    Type: AWS::EC2::Route
    Properties:
      RouteTableId:
        Ref: PrivateRouteTable
      DestinationCidrBlock: "0.0.0.0/0"
      NatGatewayId:
        Ref: NatGateway

  PrivateSubnet1RouteAssoc:
    Type: AWS::EC2::SubnetRouteTableAssociation
    Properties:
      RouteTableId:
        Ref: PrivateRouteTable
      SubnetId:
        Ref: PrivateSubnet1

  PrivateSubnet2RouteAssoc:
    Type: AWS::EC2::SubnetRouteTableAssociation
    Properties:
      RouteTableId:
        Ref: PrivateRouteTable
      SubnetId:
        Ref: PrivateSubnet2

  EcrRepository:
    Type: AWS::ECR::Repository
    Properties:
      RepositoryName: "horde-{{.Slug}}"
      ImageTagMutability: MUTABLE
      ImageScanningConfiguration:
        ScanOnPush: true
      EmptyOnDelete: true
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-ecr"

  EcsCluster:
    Type: AWS::ECS::Cluster
    Properties:
      ClusterName: "horde-{{.Slug}}"
      CapacityProviders:
        - FARGATE
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-cluster"

  WorkerSecurityGroup:
    Type: AWS::EC2::SecurityGroup
    Properties:
      GroupDescription: "horde worker egress-only"
      VpcId:
        Ref: VPC
      SecurityGroupEgress:
        - IpProtocol: "-1"
          CidrIp: "0.0.0.0/0"
          Description: "allow all outbound"
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-worker-sg"

  TaskExecutionRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName:
        Fn::Sub: "horde-{{.Slug}}-exec-${AWS::Region}"
      AssumeRolePolicyDocument:
        Version: "2012-10-17"
        Statement:
          - Effect: Allow
            Principal:
              Service: ecs-tasks.amazonaws.com
            Action: sts:AssumeRole
      ManagedPolicyArns:
        - "arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy"
      Policies:
        - PolicyName: "horde-{{.Slug}}-exec-secrets"
          PolicyDocument:
            Version: "2012-10-17"
            Statement:
              - Sid: ResolveContainerSecrets
                Effect: Allow
                Action:
                  - secretsmanager:GetSecretValue
                Resource:
                  - Ref: ClaudeCodeOauthTokenSecret
                  - Ref: GitTokenSecret
{{- range .ExtraSecrets }}
                  - Fn::Sub: "arn:aws:secretsmanager:${AWS::Region}:${AWS::AccountId}:secret:{{ .SecretName }}-*"
{{- end }}
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-exec-role"

  TaskRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName:
        Fn::Sub: "horde-{{.Slug}}-task-${AWS::Region}"
      AssumeRolePolicyDocument:
        Version: "2012-10-17"
        Statement:
          - Effect: Allow
            Principal:
              Service: ecs-tasks.amazonaws.com
            Action: sts:AssumeRole
      Policies:
        - PolicyName: "horde-{{.Slug}}-task"
          PolicyDocument:
            Version: "2012-10-17"
            Statement:
              - Sid: ArtifactsWrite
                Effect: Allow
                Action:
                  - s3:PutObject
                  - s3:GetObject
                  - s3:ListBucket
                Resource:
                  - Fn::GetAtt: [ArtifactsBucket, Arn]
                  - Fn::Sub: "${ArtifactsBucket.Arn}/*"
              - Sid: SecretsRead
                Effect: Allow
                Action:
                  - secretsmanager:GetSecretValue
                Resource:
                  - Ref: ClaudeCodeOauthTokenSecret
                  - Ref: GitTokenSecret
{{- range .ExtraSecrets }}
                  - Fn::Sub: "arn:aws:secretsmanager:${AWS::Region}:${AWS::AccountId}:secret:{{ .SecretName }}-*"
{{- end }}
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-task-role"

  LogGroup:
    Type: AWS::Logs::LogGroup
    Properties:
      LogGroupName: "/ecs/horde-worker-{{.Slug}}"
      RetentionInDays: 30

  WorkerTaskDefinition:
    Type: AWS::ECS::TaskDefinition
    Properties:
      Family: "horde-{{.Slug}}"
      RequiresCompatibilities:
        - FARGATE
      NetworkMode: awsvpc
      Cpu: "1024"
      Memory: "4096"
      ExecutionRoleArn:
        Fn::GetAtt:
          - TaskExecutionRole
          - Arn
      TaskRoleArn:
        Fn::GetAtt:
          - TaskRole
          - Arn
      ContainerDefinitions:
        - Name: horde-worker
          Image:
            Fn::Sub: "${EcrRepository.RepositoryUri}:latest"
          Essential: true
          Environment: []
          Secrets:
            - Name: CLAUDE_CODE_OAUTH_TOKEN
              ValueFrom:
                Ref: ClaudeCodeOauthTokenSecret
            - Name: GIT_TOKEN
              ValueFrom:
                Ref: GitTokenSecret
{{- range .ExtraSecrets }}
            - Name: {{ .EnvName }}
              ValueFrom:
                Fn::Sub: "arn:aws:secretsmanager:${AWS::Region}:${AWS::AccountId}:secret:{{ .SecretName }}"
{{- end }}
          LogConfiguration:
            LogDriver: awslogs
            Options:
              awslogs-group:
                Ref: LogGroup
              awslogs-region:
                Ref: "AWS::Region"
              awslogs-stream-prefix: ecs

  RunsTable:
    Type: AWS::DynamoDB::Table
    Properties:
      TableName: "horde-runs-{{.Slug}}"
      BillingMode: PAY_PER_REQUEST
      AttributeDefinitions:
        - AttributeName: id
          AttributeType: S
        - AttributeName: repo
          AttributeType: S
        - AttributeName: ticket
          AttributeType: S
        - AttributeName: status
          AttributeType: S
        - AttributeName: started_at
          AttributeType: S
        - AttributeName: instance_id
          AttributeType: S
      KeySchema:
        - AttributeName: id
          KeyType: HASH
      GlobalSecondaryIndexes:
        - IndexName: by-repo
          KeySchema:
            - AttributeName: repo
              KeyType: HASH
            - AttributeName: started_at
              KeyType: RANGE
          Projection:
            ProjectionType: ALL
        - IndexName: by-ticket
          KeySchema:
            - AttributeName: ticket
              KeyType: HASH
            - AttributeName: started_at
              KeyType: RANGE
          Projection:
            ProjectionType: ALL
        - IndexName: by-status
          KeySchema:
            - AttributeName: status
              KeyType: HASH
            - AttributeName: started_at
              KeyType: RANGE
          Projection:
            ProjectionType: ALL
        - IndexName: by-instance
          KeySchema:
            - AttributeName: instance_id
              KeyType: HASH
          Projection:
            ProjectionType: ALL
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-runs"

  ClaudeCodeOauthTokenSecret:
    Type: AWS::SecretsManager::Secret
    Properties:
      Name: "horde-{{.Slug}}-claude-code-oauth-token"
      Description: "Claude CLI OAuth token for the horde worker"
      SecretString:
        Ref: ClaudeCodeOauthToken
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-claude-code-oauth-token"

  GitTokenSecret:
    Type: AWS::SecretsManager::Secret
    Properties:
      Name: "horde-{{.Slug}}-git-token"
      Description: "Git token for the horde worker"
      SecretString:
        Ref: GitToken
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-git-token"

  ArtifactsBucket:
    Type: AWS::S3::Bucket
    Properties:
      BucketName:
        Fn::Sub: "horde-artifacts-{{.Slug}}-${AWS::AccountId}"
      PublicAccessBlockConfiguration:
        BlockPublicAcls: true
        BlockPublicPolicy: true
        IgnorePublicAcls: true
        RestrictPublicBuckets: true
      BucketEncryption:
        ServerSideEncryptionConfiguration:
          - ServerSideEncryptionByDefault:
              SSEAlgorithm: AES256
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-artifacts"

  ArtifactsBucketPolicy:
    Type: AWS::S3::BucketPolicy
    Properties:
      Bucket:
        Ref: ArtifactsBucket
      PolicyDocument:
        Version: "2012-10-17"
        Statement:
          - Sid: DenyInsecureTransport
            Effect: Deny
            Principal: "*"
            Action: "s3:*"
            Resource:
              - Fn::GetAtt: [ArtifactsBucket, Arn]
              - Fn::Sub: "${ArtifactsBucket.Arn}/*"
            Condition:
              Bool:
                "aws:SecureTransport": "false"

  HordeConfigParameter:
    Type: AWS::SSM::Parameter
    Properties:
      Name: "/horde/{{.Slug}}/config"
      Type: String
      Description: "horde CLI configuration for project {{.Slug}}"
      Value:
        Fn::Sub:
          - |
            {"cluster_arn":"${ClusterArn}","task_definition_arn":"${TaskDefArn}","subnets":["${PrivateSubnet1Id}","${PrivateSubnet2Id}"],"security_group":"${SecurityGroupId}","assign_public_ip":"DISABLED","log_group":"${LogGroupName}","log_stream_prefix":"ecs","artifacts_bucket":"${BucketName}","runs_table":"${RunsTableName}","ecr_repo_uri":"${EcrUri}","max_concurrent":20,"default_timeout_minutes":1440}
          - ClusterArn:
              Fn::GetAtt: [EcsCluster, Arn]
            TaskDefArn:
              Ref: WorkerTaskDefinition
            PrivateSubnet1Id:
              Ref: PrivateSubnet1
            PrivateSubnet2Id:
              Ref: PrivateSubnet2
            SecurityGroupId:
              Ref: WorkerSecurityGroup
            LogGroupName:
              Ref: LogGroup
            BucketName:
              Ref: ArtifactsBucket
            RunsTableName:
              Ref: RunsTable
            EcrUri:
              Fn::GetAtt: [EcrRepository, RepositoryUri]

  CliUserManagedPolicy:
    Type: AWS::IAM::ManagedPolicy
    Properties:
      ManagedPolicyName:
        Fn::Sub: "horde-{{.Slug}}-cli-${AWS::Region}"
      Description: "Permissions required by the horde CLI to launch, inspect, and terminate runs"
      PolicyDocument:
        Version: "2012-10-17"
        Statement:
          - Sid: SsmRead
            Effect: Allow
            Action:
              - ssm:GetParameter
            Resource:
              - Fn::Sub: "arn:aws:ssm:${AWS::Region}:${AWS::AccountId}:parameter/horde/{{.Slug}}/config"
          - Sid: EcsRun
            Effect: Allow
            Action:
              - ecs:RunTask
              - ecs:DescribeTasks
              - ecs:StopTask
              - ecs:ListTasks
            Resource: "*"
            Condition:
              ArnEquals:
                "ecs:cluster":
                  Fn::GetAtt: [EcsCluster, Arn]
          - Sid: EcsPassRole
            Effect: Allow
            Action:
              - iam:PassRole
            Resource:
              - Fn::GetAtt: [TaskRole, Arn]
              - Fn::GetAtt: [TaskExecutionRole, Arn]
            Condition:
              StringEquals:
                "iam:PassedToService": "ecs-tasks.amazonaws.com"
          - Sid: DynamoRunsTable
            Effect: Allow
            Action:
              - dynamodb:PutItem
              - dynamodb:GetItem
              - dynamodb:UpdateItem
              - dynamodb:DeleteItem
              - dynamodb:Query
              - dynamodb:Scan
            Resource:
              - Fn::GetAtt: [RunsTable, Arn]
              - Fn::Sub: "${RunsTable.Arn}/index/*"
          - Sid: LogsRead
            Effect: Allow
            Action:
              - logs:GetLogEvents
              - logs:FilterLogEvents
              - logs:DescribeLogStreams
            Resource:
              - Fn::GetAtt: [LogGroup, Arn]
              - Fn::Sub: "${LogGroup.Arn}:*"
          - Sid: ArtifactsRead
            Effect: Allow
            Action:
              - s3:GetObject
              - s3:ListBucket
            Resource:
              - Fn::GetAtt: [ArtifactsBucket, Arn]
              - Fn::Sub: "${ArtifactsBucket.Arn}/*"

  StatusLambdaRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName:
        Fn::Sub: "horde-{{.Slug}}-status-lambda-${AWS::Region}"
      AssumeRolePolicyDocument:
        Version: "2012-10-17"
        Statement:
          - Effect: Allow
            Principal:
              Service: lambda.amazonaws.com
            Action: sts:AssumeRole
      ManagedPolicyArns:
        - "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
      Policies:
        - PolicyName: "horde-{{.Slug}}-status-lambda"
          PolicyDocument:
            Version: "2012-10-17"
            Statement:
              - Sid: DynamoRunsTableRW
                Effect: Allow
                Action:
                  - dynamodb:GetItem
                  - dynamodb:UpdateItem
                  - dynamodb:Query
                Resource:
                  - Fn::GetAtt: [RunsTable, Arn]
                  - Fn::Sub: "${RunsTable.Arn}/index/*"
              - Sid: ArtifactsRead
                Effect: Allow
                Action:
                  - s3:GetObject
                  - s3:ListBucket
                Resource:
                  - Fn::GetAtt: [ArtifactsBucket, Arn]
                  - Fn::Sub: "${ArtifactsBucket.Arn}/*"
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-status-lambda-role"

  StatusLambda:
    Type: AWS::Lambda::Function
    Properties:
      FunctionName: "horde-{{.Slug}}-status-updater"
      Runtime: python3.12
      Handler: index.handler
      Role:
        Fn::GetAtt: [StatusLambdaRole, Arn]
      Timeout: 30
      MemorySize: 256
      Environment:
        Variables:
          RUNS_TABLE:
            Ref: RunsTable
          ARTIFACTS_BUCKET:
            Ref: ArtifactsBucket
      Code:
        ZipFile: |
          import json
          import os
          import boto3
          from botocore.exceptions import ClientError

          RUNS_TABLE = os.environ["RUNS_TABLE"]
          ARTIFACTS_BUCKET = os.environ["ARTIFACTS_BUCKET"]

          ddb = boto3.client("dynamodb")
          s3 = boto3.client("s3")

          TERMINAL = {"success", "failed", "killed"}


          def find_run_id(task_arn):
              # Query the by-instance GSI to resolve task ARN -> run id.
              resp = ddb.query(
                  TableName=RUNS_TABLE,
                  IndexName="by-instance",
                  KeyConditionExpression="instance_id = :iid",
                  ExpressionAttributeValues={":iid": {"S": task_arn}},
                  Limit=1,
              )
              items = resp.get("Items", [])
              if not items:
                  return None
              return items[0]["id"]["S"]


          def fetch_total_cost(run_id):
              # The worker uploads run-result.json under several paths (audit/
              # and artifacts/, nested under <workflow>/<ticket>). Rather than
              # hard-coding a path, list the run's prefix and pick the first
              # run-result.json we find. Any error fetching cost is non-fatal:
              # status update must still fire even if cost is unknown.
              prefix = "horde-runs/" + run_id + "/"
              try:
                  listing = s3.list_objects_v2(Bucket=ARTIFACTS_BUCKET, Prefix=prefix)
                  key = None
                  for obj in listing.get("Contents", []) or []:
                      k = obj.get("Key", "")
                      if k.endswith("/run-result.json"):
                          key = k
                          break
                  if not key:
                      return None
                  obj = s3.get_object(Bucket=ARTIFACTS_BUCKET, Key=key)
              except Exception:
                  # Any S3 error (access denied, not found, throttle) -> no cost.
                  return None
              body = obj["Body"].read()
              try:
                  data = json.loads(body)
              except ValueError:
                  return None
              cost = data.get("total_cost_usd")
              if cost is None:
                  return None
              return float(cost)


          def current_status(run_id):
              resp = ddb.get_item(
                  TableName=RUNS_TABLE,
                  Key={"id": {"S": run_id}},
                  ProjectionExpression="#s",
                  ExpressionAttributeNames={"#s": "status"},
              )
              item = resp.get("Item")
              if not item:
                  return None
              return item.get("status", {}).get("S")


          def handler(event, _context):
              detail = event.get("detail", {})
              if detail.get("lastStatus") != "STOPPED":
                  return {"skipped": "not stopped"}
              task_arn = detail.get("taskArn")
              if not task_arn:
                  return {"skipped": "no taskArn"}

              run_id = find_run_id(task_arn)
              if not run_id:
                  return {"skipped": "task not managed by horde"}

              existing = current_status(run_id)
              if existing in TERMINAL:
                  return {"skipped": "already terminal", "run_id": run_id, "status": existing}

              containers = detail.get("containers", [])
              exit_code = None
              if containers:
                  exit_code = containers[0].get("exitCode")
              status = "success" if exit_code == 0 else "failed"

              stopped_at = detail.get("stoppedAt")  # ISO-8601 string
              cost = fetch_total_cost(run_id)

              names = {"#s": "status", "#ec": "exit_code", "#ca": "completed_at"}
              values = {
                  ":s": {"S": status},
                  ":ca": {"S": stopped_at} if stopped_at else {"NULL": True},
              }
              set_exprs = ["#s = :s", "#ca = :ca"]
              if exit_code is not None:
                  values[":ec"] = {"N": str(int(exit_code))}
                  set_exprs.append("#ec = :ec")
              if cost is not None:
                  names["#tc"] = "total_cost_usd"
                  values[":tc"] = {"N": str(cost)}
                  set_exprs.append("#tc = :tc")

              ddb.update_item(
                  TableName=RUNS_TABLE,
                  Key={"id": {"S": run_id}},
                  UpdateExpression="SET " + ", ".join(set_exprs),
                  ExpressionAttributeNames=names,
                  ExpressionAttributeValues=values,
              )
              return {"updated": True, "run_id": run_id, "status": status, "exit_code": exit_code}
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-status-lambda"

  StatusEventRule:
    Type: AWS::Events::Rule
    Properties:
      Name: "horde-{{.Slug}}-status"
      EventPattern:
        source:
          - aws.ecs
        detail-type:
          - "ECS Task State Change"
        detail:
          clusterArn:
            - Fn::GetAtt: [EcsCluster, Arn]
          lastStatus:
            - STOPPED
      State: ENABLED
      Targets:
        - Id: StatusLambdaTarget
          Arn:
            Fn::GetAtt: [StatusLambda, Arn]

  StatusLambdaInvokePermission:
    Type: AWS::Lambda::Permission
    Properties:
      FunctionName:
        Fn::GetAtt: [StatusLambda, Arn]
      Action: lambda:InvokeFunction
      Principal: events.amazonaws.com
      SourceArn:
        Fn::GetAtt: [StatusEventRule, Arn]

Outputs:
  VpcId:
    Value:
      Ref: VPC
    Export:
      Name: "horde-{{.Slug}}-vpc-id"

  PublicSubnetIds:
    Value:
      Fn::Join:
        - ","
        - - Ref: PublicSubnet1
          - Ref: PublicSubnet2
    Export:
      Name: "horde-{{.Slug}}-public-subnets"

  PrivateSubnetIds:
    Value:
      Fn::Join:
        - ","
        - - Ref: PrivateSubnet1
          - Ref: PrivateSubnet2
    Export:
      Name: "horde-{{.Slug}}-private-subnets"

  ClusterArn:
    Value:
      Fn::GetAtt:
        - EcsCluster
        - Arn
    Export:
      Name: "horde-{{.Slug}}-cluster-arn"

  TaskDefinitionArn:
    Value:
      Ref: WorkerTaskDefinition
    Export:
      Name: "horde-{{.Slug}}-task-definition-arn"

  WorkerSecurityGroupId:
    Value:
      Ref: WorkerSecurityGroup
    Export:
      Name: "horde-{{.Slug}}-worker-sg"

  EcrRepositoryUri:
    Value:
      Fn::GetAtt:
        - EcrRepository
        - RepositoryUri
    Export:
      Name: "horde-{{.Slug}}-ecr-uri"

  LogGroupName:
    Value:
      Ref: LogGroup
    Export:
      Name: "horde-{{.Slug}}-log-group"

  RunsTableName:
    Value:
      Ref: RunsTable
    Export:
      Name: "horde-{{.Slug}}-runs-table"

  ArtifactsBucketName:
    Value:
      Ref: ArtifactsBucket
    Export:
      Name: "horde-{{.Slug}}-artifacts-bucket"

  ClaudeCodeOauthTokenSecretArn:
    Value:
      Ref: ClaudeCodeOauthTokenSecret
    Export:
      Name: "horde-{{.Slug}}-claude-code-oauth-token-arn"

  GitTokenSecretArn:
    Value:
      Ref: GitTokenSecret
    Export:
      Name: "horde-{{.Slug}}-git-token-arn"

  SsmConfigPath:
    Value:
      Ref: HordeConfigParameter
    Export:
      Name: "horde-{{.Slug}}-ssm-config-path"

  CliUserManagedPolicyArn:
    Value:
      Ref: CliUserManagedPolicy
    Export:
      Name: "horde-{{.Slug}}-cli-policy-arn"

  StatusLambdaArn:
    Value:
      Fn::GetAtt: [StatusLambda, Arn]
    Export:
      Name: "horde-{{.Slug}}-status-lambda-arn"
