AWSTemplateFormatVersion: "2010-09-09"
Description: "horde stack for project {{.Slug}}"

Parameters:
  AnthropicApiKey:
    Type: String
    NoEcho: true
    Description: "Claude API key used by the worker container"
    MinLength: 1
  GitToken:
    Type: String
    NoEcho: true
    Description: "Git provider token used by the worker container for clone/push"
    MinLength: 1

Resources:
  VPC:
    Type: AWS::EC2::VPC
    Properties:
      CidrBlock: "10.0.0.0/16"
      EnableDnsHostnames: true
      EnableDnsSupport: true
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-vpc"

  InternetGateway:
    Type: AWS::EC2::InternetGateway
    Properties:
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-igw"

  InternetGatewayAttachment:
    Type: AWS::EC2::VPCGatewayAttachment
    Properties:
      VpcId:
        Ref: VPC
      InternetGatewayId:
        Ref: InternetGateway

  PublicSubnet1:
    Type: AWS::EC2::Subnet
    Properties:
      VpcId:
        Ref: VPC
      CidrBlock: "10.0.1.0/24"
      AvailabilityZone:
        Fn::Select:
          - 0
          - Fn::GetAZs: ""
      MapPublicIpOnLaunch: true
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-public-1"

  PublicSubnet2:
    Type: AWS::EC2::Subnet
    Properties:
      VpcId:
        Ref: VPC
      CidrBlock: "10.0.2.0/24"
      AvailabilityZone:
        Fn::Select:
          - 1
          - Fn::GetAZs: ""
      MapPublicIpOnLaunch: true
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-public-2"

  PrivateSubnet1:
    Type: AWS::EC2::Subnet
    Properties:
      VpcId:
        Ref: VPC
      CidrBlock: "10.0.11.0/24"
      AvailabilityZone:
        Fn::Select:
          - 0
          - Fn::GetAZs: ""
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-private-1"

  PrivateSubnet2:
    Type: AWS::EC2::Subnet
    Properties:
      VpcId:
        Ref: VPC
      CidrBlock: "10.0.12.0/24"
      AvailabilityZone:
        Fn::Select:
          - 1
          - Fn::GetAZs: ""
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-private-2"

  NatGatewayEIP:
    Type: AWS::EC2::EIP
    DependsOn: InternetGatewayAttachment
    Properties:
      Domain: vpc

  NatGateway:
    Type: AWS::EC2::NatGateway
    Properties:
      AllocationId:
        Fn::GetAtt:
          - NatGatewayEIP
          - AllocationId
      SubnetId:
        Ref: PublicSubnet1
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-nat"

  PublicRouteTable:
    Type: AWS::EC2::RouteTable
    Properties:
      VpcId:
        Ref: VPC
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-public-rt"

  PublicDefaultRoute:
    Type: AWS::EC2::Route
    DependsOn: InternetGatewayAttachment
    Properties:
      RouteTableId:
        Ref: PublicRouteTable
      DestinationCidrBlock: "0.0.0.0/0"
      GatewayId:
        Ref: InternetGateway

  PublicSubnet1RouteAssoc:
    Type: AWS::EC2::SubnetRouteTableAssociation
    Properties:
      RouteTableId:
        Ref: PublicRouteTable
      SubnetId:
        Ref: PublicSubnet1

  PublicSubnet2RouteAssoc:
    Type: AWS::EC2::SubnetRouteTableAssociation
    Properties:
      RouteTableId:
        Ref: PublicRouteTable
      SubnetId:
        Ref: PublicSubnet2

  PrivateRouteTable:
    Type: AWS::EC2::RouteTable
    Properties:
      VpcId:
        Ref: VPC
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-private-rt"

  PrivateDefaultRoute:
    Type: AWS::EC2::Route
    Properties:
      RouteTableId:
        Ref: PrivateRouteTable
      DestinationCidrBlock: "0.0.0.0/0"
      NatGatewayId:
        Ref: NatGateway

  PrivateSubnet1RouteAssoc:
    Type: AWS::EC2::SubnetRouteTableAssociation
    Properties:
      RouteTableId:
        Ref: PrivateRouteTable
      SubnetId:
        Ref: PrivateSubnet1

  PrivateSubnet2RouteAssoc:
    Type: AWS::EC2::SubnetRouteTableAssociation
    Properties:
      RouteTableId:
        Ref: PrivateRouteTable
      SubnetId:
        Ref: PrivateSubnet2

  EcrRepository:
    Type: AWS::ECR::Repository
    Properties:
      RepositoryName: "horde-{{.Slug}}"
      ImageTagMutability: MUTABLE
      ImageScanningConfiguration:
        ScanOnPush: true
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-ecr"

  EcsCluster:
    Type: AWS::ECS::Cluster
    Properties:
      ClusterName: "horde-{{.Slug}}"
      CapacityProviders:
        - FARGATE
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-cluster"

  WorkerSecurityGroup:
    Type: AWS::EC2::SecurityGroup
    Properties:
      GroupDescription: "horde worker egress-only"
      VpcId:
        Ref: VPC
      SecurityGroupEgress:
        - IpProtocol: "-1"
          CidrIp: "0.0.0.0/0"
          Description: "allow all outbound"
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-worker-sg"

  TaskExecutionRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName:
        Fn::Sub: "horde-{{.Slug}}-exec-${AWS::Region}"
      AssumeRolePolicyDocument:
        Version: "2012-10-17"
        Statement:
          - Effect: Allow
            Principal:
              Service: ecs-tasks.amazonaws.com
            Action: sts:AssumeRole
      ManagedPolicyArns:
        - "arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy"
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-exec-role"

  TaskRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName:
        Fn::Sub: "horde-{{.Slug}}-task-${AWS::Region}"
      AssumeRolePolicyDocument:
        Version: "2012-10-17"
        Statement:
          - Effect: Allow
            Principal:
              Service: ecs-tasks.amazonaws.com
            Action: sts:AssumeRole
      Policies:
        - PolicyName: "horde-{{.Slug}}-task"
          PolicyDocument:
            Version: "2012-10-17"
            Statement:
              - Sid: ArtifactsWrite
                Effect: Allow
                Action:
                  - s3:PutObject
                Resource:
                  - Fn::Sub: "${ArtifactsBucket.Arn}/*"
              - Sid: SecretsRead
                Effect: Allow
                Action:
                  - secretsmanager:GetSecretValue
                Resource:
                  - Ref: AnthropicApiKeySecret
                  - Ref: GitTokenSecret
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-task-role"

  LogGroup:
    Type: AWS::Logs::LogGroup
    Properties:
      LogGroupName: "/ecs/horde-worker-{{.Slug}}"
      RetentionInDays: 30

  WorkerTaskDefinition:
    Type: AWS::ECS::TaskDefinition
    Properties:
      Family: "horde-{{.Slug}}"
      RequiresCompatibilities:
        - FARGATE
      NetworkMode: awsvpc
      Cpu: "1024"
      Memory: "4096"
      ExecutionRoleArn:
        Fn::GetAtt:
          - TaskExecutionRole
          - Arn
      TaskRoleArn:
        Fn::GetAtt:
          - TaskRole
          - Arn
      ContainerDefinitions:
        - Name: worker
          Image:
            Fn::Sub: "${EcrRepository.RepositoryUri}:latest"
          Essential: true
          Environment: []
          Secrets:
            - Name: CLAUDE_CODE_OAUTH_TOKEN
              ValueFrom:
                Ref: AnthropicApiKeySecret
            - Name: GIT_TOKEN
              ValueFrom:
                Ref: GitTokenSecret
          LogConfiguration:
            LogDriver: awslogs
            Options:
              awslogs-group:
                Ref: LogGroup
              awslogs-region:
                Ref: "AWS::Region"
              awslogs-stream-prefix: ecs

  RunsTable:
    Type: AWS::DynamoDB::Table
    Properties:
      TableName: "horde-runs-{{.Slug}}"
      BillingMode: PAY_PER_REQUEST
      AttributeDefinitions:
        - AttributeName: id
          AttributeType: S
        - AttributeName: repo
          AttributeType: S
        - AttributeName: ticket
          AttributeType: S
        - AttributeName: status
          AttributeType: S
        - AttributeName: started_at
          AttributeType: S
        - AttributeName: instance_id
          AttributeType: S
      KeySchema:
        - AttributeName: id
          KeyType: HASH
      GlobalSecondaryIndexes:
        - IndexName: by-repo
          KeySchema:
            - AttributeName: repo
              KeyType: HASH
            - AttributeName: started_at
              KeyType: RANGE
          Projection:
            ProjectionType: ALL
        - IndexName: by-ticket
          KeySchema:
            - AttributeName: ticket
              KeyType: HASH
            - AttributeName: started_at
              KeyType: RANGE
          Projection:
            ProjectionType: ALL
        - IndexName: by-status
          KeySchema:
            - AttributeName: status
              KeyType: HASH
            - AttributeName: started_at
              KeyType: RANGE
          Projection:
            ProjectionType: ALL
        - IndexName: by-instance
          KeySchema:
            - AttributeName: instance_id
              KeyType: HASH
          Projection:
            ProjectionType: ALL
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-runs"

  AnthropicApiKeySecret:
    Type: AWS::SecretsManager::Secret
    Properties:
      Name: "horde-{{.Slug}}-anthropic-api-key"
      Description: "Claude API key for the horde worker"
      SecretString:
        Ref: AnthropicApiKey
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-anthropic-api-key"

  GitTokenSecret:
    Type: AWS::SecretsManager::Secret
    Properties:
      Name: "horde-{{.Slug}}-git-token"
      Description: "Git token for the horde worker"
      SecretString:
        Ref: GitToken
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-git-token"

  ArtifactsBucket:
    Type: AWS::S3::Bucket
    Properties:
      BucketName:
        Fn::Sub: "horde-artifacts-{{.Slug}}-${AWS::AccountId}"
      PublicAccessBlockConfiguration:
        BlockPublicAcls: true
        BlockPublicPolicy: true
        IgnorePublicAcls: true
        RestrictPublicBuckets: true
      BucketEncryption:
        ServerSideEncryptionConfiguration:
          - ServerSideEncryptionByDefault:
              SSEAlgorithm: AES256
      Tags:
        - Key: Name
          Value: "horde-{{.Slug}}-artifacts"

  ArtifactsBucketPolicy:
    Type: AWS::S3::BucketPolicy
    Properties:
      Bucket:
        Ref: ArtifactsBucket
      PolicyDocument:
        Version: "2012-10-17"
        Statement:
          - Sid: DenyInsecureTransport
            Effect: Deny
            Principal: "*"
            Action: "s3:*"
            Resource:
              - Fn::GetAtt: [ArtifactsBucket, Arn]
              - Fn::Sub: "${ArtifactsBucket.Arn}/*"
            Condition:
              Bool:
                "aws:SecureTransport": "false"

  CliUserManagedPolicy:
    Type: AWS::IAM::ManagedPolicy
    Properties:
      ManagedPolicyName:
        Fn::Sub: "horde-{{.Slug}}-cli-${AWS::Region}"
      Description: "Permissions required by the horde CLI to launch, inspect, and terminate runs"
      PolicyDocument:
        Version: "2012-10-17"
        Statement:
          - Sid: SsmRead
            Effect: Allow
            Action:
              - ssm:GetParameter
            Resource:
              - Fn::Sub: "arn:aws:ssm:${AWS::Region}:${AWS::AccountId}:parameter/horde/{{.Slug}}/config"
          - Sid: EcsRun
            Effect: Allow
            Action:
              - ecs:RunTask
              - ecs:DescribeTasks
              - ecs:StopTask
              - ecs:ListTasks
            Resource: "*"
            Condition:
              ArnEquals:
                "ecs:cluster":
                  Fn::GetAtt: [EcsCluster, Arn]
          - Sid: EcsPassRole
            Effect: Allow
            Action:
              - iam:PassRole
            Resource:
              - Fn::GetAtt: [TaskRole, Arn]
              - Fn::GetAtt: [TaskExecutionRole, Arn]
            Condition:
              StringEquals:
                "iam:PassedToService": "ecs-tasks.amazonaws.com"
          - Sid: DynamoRunsTable
            Effect: Allow
            Action:
              - dynamodb:PutItem
              - dynamodb:GetItem
              - dynamodb:UpdateItem
              - dynamodb:DeleteItem
              - dynamodb:Query
              - dynamodb:Scan
            Resource:
              - Fn::GetAtt: [RunsTable, Arn]
              - Fn::Sub: "${RunsTable.Arn}/index/*"
          - Sid: LogsRead
            Effect: Allow
            Action:
              - logs:GetLogEvents
              - logs:FilterLogEvents
              - logs:DescribeLogStreams
            Resource:
              - Fn::GetAtt: [LogGroup, Arn]
              - Fn::Sub: "${LogGroup.Arn}:*"
          - Sid: ArtifactsRead
            Effect: Allow
            Action:
              - s3:GetObject
              - s3:ListBucket
            Resource:
              - Fn::GetAtt: [ArtifactsBucket, Arn]
              - Fn::Sub: "${ArtifactsBucket.Arn}/*"

Outputs:
  VpcId:
    Value:
      Ref: VPC
    Export:
      Name: "horde-{{.Slug}}-vpc-id"

  PublicSubnetIds:
    Value:
      Fn::Join:
        - ","
        - - Ref: PublicSubnet1
          - Ref: PublicSubnet2
    Export:
      Name: "horde-{{.Slug}}-public-subnets"

  PrivateSubnetIds:
    Value:
      Fn::Join:
        - ","
        - - Ref: PrivateSubnet1
          - Ref: PrivateSubnet2
    Export:
      Name: "horde-{{.Slug}}-private-subnets"

  ClusterArn:
    Value:
      Fn::GetAtt:
        - EcsCluster
        - Arn
    Export:
      Name: "horde-{{.Slug}}-cluster-arn"

  TaskDefinitionArn:
    Value:
      Ref: WorkerTaskDefinition
    Export:
      Name: "horde-{{.Slug}}-task-definition-arn"

  WorkerSecurityGroupId:
    Value:
      Ref: WorkerSecurityGroup
    Export:
      Name: "horde-{{.Slug}}-worker-sg"

  EcrRepositoryUri:
    Value:
      Fn::GetAtt:
        - EcrRepository
        - RepositoryUri
    Export:
      Name: "horde-{{.Slug}}-ecr-uri"

  LogGroupName:
    Value:
      Ref: LogGroup
    Export:
      Name: "horde-{{.Slug}}-log-group"

  RunsTableName:
    Value:
      Ref: RunsTable
    Export:
      Name: "horde-{{.Slug}}-runs-table"

  ArtifactsBucketName:
    Value:
      Ref: ArtifactsBucket
    Export:
      Name: "horde-{{.Slug}}-artifacts-bucket"

  AnthropicApiKeySecretArn:
    Value:
      Ref: AnthropicApiKeySecret
    Export:
      Name: "horde-{{.Slug}}-anthropic-api-key-arn"

  GitTokenSecretArn:
    Value:
      Ref: GitTokenSecret
    Export:
      Name: "horde-{{.Slug}}-git-token-arn"

  CliUserManagedPolicyArn:
    Value:
      Ref: CliUserManagedPolicy
    Export:
      Name: "horde-{{.Slug}}-cli-policy-arn"
